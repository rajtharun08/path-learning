# ─────────────────────────────────────────────
# API Gateway — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# Upstream service URLs
USER_SERVICE_URL=http://user-service:8001
CONTENT_SERVICE_URL=http://content-service:8002
PROGRESS_SERVICE_URL=http://progress-service:8003
ANALYTICS_SERVICE_URL=http://analytics-service:8004
RECOMMENDATION_SERVICE_URL=http://recommendation-service:8005

# Gateway port
GATEWAY_PORT=8000

# Rate limiting (requests per minute per IP)
RATE_LIMIT_PER_MINUTE=100
