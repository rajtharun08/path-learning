# ─────────────────────────────────────────────
# Progress Service — Environment Configuration
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@progress-db:5432/progress_db

# Content service URL (for fetching video durations)
CONTENT_SERVICE_URL=http://content-service:8002

# Service port
SERVICE_PORT=8003

# Rate limiting (requests per minute per IP)
RATE_LIMIT_PER_MINUTE=100

# Threshold for marking a video as completed (90% of duration)
COMPLETION_THRESHOLD=0.90
